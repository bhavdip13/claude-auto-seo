# ============================================================
# Claude Auto SEO + Digital Marketing — Environment Variables
# Copy to .env and fill in your credentials. Never commit .env
# ============================================================

# ── YOUR SITE ──────────────────────────────────────────────
SITE_NAME=Your Site Name
WP_URL=https://yoursite.com

# ── WORDPRESS (App Password) ───────────────────────────────
WP_USERNAME=your_wordpress_username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ── BRAND + LOGO ───────────────────────────────────────────
BRAND_COLOR_PRIMARY=#0f3460
BRAND_COLOR_SECONDARY=#e74c3c
BRAND_COLOR_TEXT=#ffffff
LOGO_PATH=assets/logo.png
UNSPLASH_ACCESS_KEY=your_unsplash_key

# ── META (FACEBOOK + INSTAGRAM) ────────────────────────────
META_ACCESS_TOKEN=your_meta_page_access_token
FACEBOOK_PAGE_ID=your_facebook_page_id
INSTAGRAM_USER_ID=your_instagram_business_user_id
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# ── TWITTER / X ────────────────────────────────────────────
TWITTER_API_KEY=your_key
TWITTER_API_SECRET=your_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret
TWITTER_BEARER_TOKEN=your_bearer_token

# ── LINKEDIN ────────────────────────────────────────────────
LINKEDIN_ACCESS_TOKEN=your_token
LINKEDIN_CLIENT_ID=your_client_id
LINKEDIN_CLIENT_SECRET=your_client_secret

# ── PINTEREST ───────────────────────────────────────────────
PINTEREST_ACCESS_TOKEN=your_token
PINTEREST_BOARD_ID=your_board_id

# ── TIKTOK ──────────────────────────────────────────────────
TIKTOK_ACCESS_TOKEN=your_token

# ── GOOGLE MY BUSINESS ──────────────────────────────────────
GOOGLE_GMB_ACCESS_TOKEN=your_gmb_token
GMB_LOCATION_ID=your_gmb_location_id
GOOGLE_APPLICATION_CREDENTIALS=config/google-service-account.json

# ── GOOGLE ANALYTICS + SEARCH CONSOLE ──────────────────────
GA4_PROPERTY_ID=123456789
GSC_SITE_URL=https://yoursite.com

# ── EXTERNAL BLOG PLATFORMS ─────────────────────────────────
MEDIUM_INTEGRATION_TOKEN=your_medium_token
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
DEVTO_API_KEY=your_devto_key
HASHNODE_API_KEY=your_hashnode_key
HASHNODE_PUBLICATION_ID=your_hashnode_pub_id

# ── DATAFORSEO ──────────────────────────────────────────────
DATAFORSEO_LOGIN=email@example.com
DATAFORSEO_PASSWORD=your_dataforseo_password

# ── AHREFS / SEMRUSH ────────────────────────────────────────
AHREFS_API_KEY=your_ahrefs_key
SEMRUSH_API_KEY=your_semrush_key

# ── NOTIFICATIONS ───────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx
NOTIFICATION_EMAIL=you@yoursite.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password
