    "min_word_count": 2000,
    "min_seo_score": 75,
    "require_internal_links": true,
    "min_internal_links": 3
  },
  "notifications": {
    "daily_report_email": {
      "enabled": true,
      "time": "20:00",
      "timezone": "America/New_York",
      "_note": "Report emailed every day at 8 PM. Set SMTP_USER, SMTP_PASS, NOTIFICATION_EMAIL in .env"
    },
    "weekly_seo_digest": {
      "enabled": true,
      "day": "monday",
      "time": "08:00"
    },
    "festival_posts": {
      "enabled": true,
      "time": "01:00",
      "_note": "Festival posts at 1AM on festival days"
    },
    "alert_on_error": true,
    "alert_on_ranking_drop": true,
    "ranking_drop_threshold": 5
  }
