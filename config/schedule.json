{
  "_comment": "Claude Auto SEO + Digital Marketing \u2014 Schedule Configuration. Set enabled:true to activate each platform.",
  "wordpress_internal": {
    "enabled": true,
    "frequency": "daily",
    "time": "09:00",
    "posts_per_run": 1,
    "auto_publish": false,
    "review_required": true,
    "min_seo_score": 75,
    "generate_banner_image": true
